{
  "name": "contact_enrichment",
  "description": "Fetch contacts from Zoho CRM with full field details for enrichment and analysis",
  "version": "1.0",
  "connector": "zoho",
  "llm_provider": "claude",
  "supports": ["text"],
  "steps": [
    {
      "step_name": "fetch_contacts",
      "tool": "get_zoho_contacts",
      "params": {
        "limit": 50,
        "page": 1,
        "fields": ["First_Name", "Last_Name", "Email", "Phone", "Account_Name", "Lead_Source", "Created_Time"]
      },
      "on_error": "stop"
    }
  ]
}
