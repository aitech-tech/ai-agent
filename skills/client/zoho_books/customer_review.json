{
  "name": "customer_review",
  "display_name": "Customer Review",
  "description": "Fetch all customers",
  "version": "1.0",
  "format": "simple",
  "source_doc": "customer_review.docx",
  "steps": [
    {
      "step_name": "fetch_data",
      "tool": "zoho_books_list_contacts",
      "params": {
        "contact_type": "customer",
        "limit": 30,
        "status": "overdue"
      },
      "on_error": "stop"
    },
    {
      "step_name": "summarise",
      "tool": "summarise_results",
      "params": {
        "group_by": "status",
        "source_step": "fetch_data"
      },
      "on_error": "continue"
    }
  ],
  "business_rules": "Flag invoices above 50000",
  "notes": "Indian GST applies"
}