ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REDIRECT_URI=http://localhost:8000/callback

# Tool exposure mode: "customer" (default) or "developer"
# customer: router tools + auth/org + CUD tools only (~47 tools exposed to Claude)
# developer: all 91 tools exposed (for building, testing, debugging)
RECKLABS_TOOL_MODE=customer
