{
  "name": "group_by_status",
  "display_name": "Group By Status",
  "description": "Summarise invoices grouped by status",
  "version": "1.0",
  "format": "simple",
  "source_doc": "group_test.docx",
  "steps": [
    {
      "step_name": "fetch_data",
      "tool": "zoho_books_list_invoices",
      "params": {
        "limit": 30,
        "status": "overdue"
      },
      "on_error": "stop"
    },
    {
      "step_name": "summarise",
      "tool": "summarise_results",
      "params": {
        "group_by": "status",
        "source_step": "fetch_data"
      },
      "on_error": "continue"
    }
  ],
  "business_rules": "Flag invoices above 50000",
  "notes": "Indian GST applies"
}