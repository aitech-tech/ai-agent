{
  "name": "pipeline_review",
  "description": "Full CRM pipeline review: fetch leads, contacts, and accounts in one workflow",
  "version": "1.0",
  "connector": "zoho",
  "llm_provider": "claude",
  "supports": ["text"],
  "steps": [
    {
      "step_name": "fetch_leads",
      "tool": "get_zoho_leads",
      "params": {
        "limit": 20,
        "page": 1
      },
      "on_error": "continue"
    },
    {
      "step_name": "fetch_contacts",
      "tool": "get_zoho_contacts",
      "params": {
        "limit": 20,
        "page": 1
      },
      "on_error": "continue"
    },
    {
      "step_name": "fetch_accounts",
      "tool": "get_zoho_accounts",
      "params": {
        "limit": 20
      },
      "on_error": "continue"
    }
  ]
}
